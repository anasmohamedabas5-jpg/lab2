#include<iostream>
#include<string>
using namespace std;

int main(){
    string s;
    getline(cin, s); 
    int fer[300] = {0};
    int count = 0;
    for(int i = 0; i < s.length(); i++){
        char ch = s[i];
        if(ch >= 'a' && ch <= 'z'){
            if(fer[ch] == 0){
                count++;
                fer[ch] = 1;
            }
        }
    }

    cout << count << "\n";
    return 0;
}
